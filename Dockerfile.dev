FROM node:24-slim AS base

# Install build dependencies for native modules
RUN apt-get update && apt-get install -y \
    python3 \
    make \
    g++ \
    gcc \
    git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Increase pnpm network timeout
ENV PNPM_CONFIG_FETCH_TIMEOUT=300000
ENV PNPM_CONFIG_FETCH_RETRY_MAXTIMEOUT=600000

# Enable pnpm
RUN corepack enable && corepack prepare pnpm@11.5.1 --activate

# Copy workspace configurations and all source code to ensure dependencies are resolved
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc ./
COPY apps/ ./apps/
COPY packages/ ./packages/

# Install dependencies and build the entire monorepo
RUN pnpm install --no-frozen-lockfile
RUN pnpm build